#!/usr/bin/env bash
# Deterministic mock squeue for solx parity testing.
# Honors the exact argv shapes solx emits:
#   squeue -u USER -h -o '%i|%j|%T|%M|%L|%P|%R'   -> pipe rows
#   squeue -h -j JOBID -O TimeLeft                 -> time-left value
# Env toggles:
#   MOCK_SQUEUE_EMPTY=1       -> no rows
#   MOCK_SQUEUE_FAIL=1        -> exit 1 with stderr "boom"
#   MOCK_SQUEUE_TWORUNNING=1  -> both rows RUNNING (most-recent paths)
set -u

if [ "${MOCK_SQUEUE_FAIL:-}" = "1" ]; then
    echo "boom" >&2
    exit 1
fi

has_O_timeleft=0
has_pipe_fmt=0
prev=""
for a in "$@"; do
    if [ "$prev" = "-O" ] && [ "$a" = "TimeLeft" ]; then has_O_timeleft=1; fi
    case "$a" in *"%i|%j"*) has_pipe_fmt=1 ;; esac
    prev="$a"
done

if [ "$has_O_timeleft" = "1" ]; then
    echo "2-03:04:05"
    exit 0
fi

if [ "$has_pipe_fmt" = "1" ]; then
    if [ "${MOCK_SQUEUE_EMPTY:-}" = "1" ]; then
        exit 0
    fi
    echo "54800001|solx-default|RUNNING|1:23|2-03:04:05|general|sc042"
    if [ "${MOCK_SQUEUE_TWORUNNING:-}" = "1" ]; then
        echo "54800002|jupyter|RUNNING|0:10|3:50:00|public|sc043"
    else
        echo "54800002|jupyter|PENDING|0:00|4:00:00|public|(Priority)"
    fi
    exit 0
fi

# Fallback: human table (not used by solx itself)
echo "             JOBID PARTITION     NAME     USER ST       TIME  NODES NODELIST(REASON)"
echo "          54800001   general solx-def   sparky  R       1:23      1 sc042"
exit 0
